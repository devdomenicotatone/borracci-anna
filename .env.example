# ============================================================================
# Borracci Anna - Variabili d'ambiente
# ----------------------------------------------------------------------------
# Copia questo file in ".env.local" e compila i valori reali.
# Il progetto COMPILA anche senza queste env (degrada con dati di esempio),
# ma per funzionare davvero (DB + pagamenti) vanno tutte configurate.
# Le variabili con prefisso NEXT_PUBLIC_ sono esposte al browser: non metterci
# mai segreti server-side.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# URL del progetto Supabase (es. https://abcdxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key: sicura da esporre al client, protetta dalle RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: SEGRETA, bypassa le RLS. Solo server (webhook Stripe).
# NON committare mai questa chiave e non esporla al client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe -----------------------------------------------------------------
# Chiave segreta server (sk_test_... in sviluppo, sk_live_... in produzione).
STRIPE_SECRET_KEY=
# Secret di firma del webhook (whsec_...), dato dalla dashboard o da `stripe listen`.
STRIPE_WEBHOOK_SECRET=
# Publishable key per il client (pk_test_... / pk_live_...).
# NON ancora usata: il checkout attuale usa solo STRIPE_SECRET_KEY server-side
# (redirect a Stripe Checkout). Riservata per un futuro Stripe Elements/embedded.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Sito -------------------------------------------------------------------
# URL pubblico del sito, usato per le redirect di Stripe Checkout e per i link
# nelle email d'ordine. In sviluppo: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Spedizione -------------------------------------------------------------
# Tariffe in CENTESIMI. Valori di partenza da confermare col preventivo reale
# dell'aggregatore (Packlink).
#
# Soglia spedizione gratuita: PUBBLICA (NEXT_PUBLIC) perche la barra "spedizione
# gratis" la mostra nel browser. Default 8900 = 89,00 EUR.
NEXT_PUBLIC_FREE_SHIPPING_CENTS=8900
#
# Tariffa UNICA nazionale (decisione titolare, audit lug 2026 finding 16: niente
# piu zone continentale/isole, il supplemento isole del corriere e assorbito dal
# negozio). Server-only (NO NEXT_PUBLIC): usata solo dal checkout lato server e
# letta a RUNTIME -> per cambiarla basta modificarla e RIAVVIARE, senza rebuild.
# NOTA: la pagina /condizioni-di-vendita mostra la stessa cifra ma e statica
# (valore incollato al build): dopo un cambio serve anche un deploy.
# Default 590 = 5,90 EUR. La storica SHIPPING_IT_CONTINENTE_CENTS resta letta
# come fallback se questa manca; SHIPPING_IT_ISOLE_CENTS non e piu usata.
SHIPPING_IT_CENTS=590

# --- Fornitore Ingrosso BLT (import + sync giornaliero) ---------------------
# Credenziali dell'account cliente su https://www.ingrossoblt.com. Usate dal
# server per: (1) vedere il prezzo consigliato durante l'import; (2) il cron
# giornaliero che scarica il CSV del catalogo e allinea le giacenze.
# DEVE essere un account abilitato al download del catalogo CSV dall'area
# riservata. Solo server (mai NEXT_PUBLIC).
BLT_EMAIL=
BLT_PASSWORD=

# --- Email (notifiche ordini, via Gmail SMTP) -------------------------------
# Invio email transazionali con nodemailer + Gmail. Richiede 2FA attiva e una
# APP PASSWORD (16 caratteri) da https://myaccount.google.com/apppasswords.
# Solo server (mai NEXT_PUBLIC). Se assenti, le email vengono saltate e il
# flusso ordini continua a funzionare.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Override opzionali (hanno gia i default Gmail):
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=465

# --- Anthropic (generazione schede AI) --------------------------------------
# API key per @anthropic-ai/sdk, usata per generare/arricchire le schede
# prodotto (scheda automatica e import da fornitore). Solo server (mai
# NEXT_PUBLIC). Se assente, le feature AI degradano: scheda manuale e import
# senza arricchimento, il flusso continua a funzionare.
ANTHROPIC_API_KEY=

# --- Cron / Sync catalogo ---------------------------------------------------
# Segreto che protegge la rotta /api/cron/sync-catalogo. Vercel Cron lo invia
# come header "Authorization: Bearer <CRON_SECRET>". Genera un valore lungo e
# casuale (es. `openssl rand -hex 32`) e impostalo ANCHE nelle env di Vercel.
# Solo server (mai NEXT_PUBLIC). Se assente, la rotta rifiuta ogni richiesta.
CRON_SECRET=
